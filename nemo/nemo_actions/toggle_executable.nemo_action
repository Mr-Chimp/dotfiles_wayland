[Nemo Action]
Name=Toggle Executable
Comment=Add or remove executable permission
Exec=sh -c 'if [ -x "%F" ]; then chmod -x "%F"; else chmod +x "%F"; fi'
Icon-Name=system-run
Selection=s
Extensions=sh;py;pl;run;rb;js;php;lua;go;exe;bin;run;
Mimetypes=application/x-shellscript;application/x-executable;text/x-python;application/x-perl;application/x-ruby;application/x-go-binary;application/x-dosexec;
Conditions=any
